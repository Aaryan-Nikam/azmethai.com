{
  "manifest_version": 3,
  "name": "Azmeth Browser Agent",
  "version": "1.0.0",
  "description": "Connects your browser to the Azmeth autonomous agent engine, enabling stealth browser automation using your real sessions and identity.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Azmeth Browser Agent",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "activeTab",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
