# Core app
NEXT_PUBLIC_APP_URL=https://azmethai.com
NODE_ENV=production

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI
OPENAI_API_KEY=

# Queue worker auth
CRON_SECRET=

# Meta inbound (Instagram/Facebook)
NEXT_PUBLIC_META_APP_ID=
META_APP_SECRET=
NEXT_PUBLIC_META_REDIRECT_URI=https://azmethai.com/api/auth/meta/callback
META_WEBHOOK_VERIFY_TOKEN=

# Outbound email (choose one path)
# Gmail path
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_SENDER_NAME=Azmeth

# SMTP path (optional alternative to Gmail)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Azmeth

# Optional outbound controls
OUTBOUND_DAILY_LIMIT=50
APIFY_API_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
